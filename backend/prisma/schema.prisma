generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id         Int    @id @default(autoincrement())
  firstName  String
  lastName   String
  department String

  roleId     Int
  role       Role   @relation(fields: [roleId], references: [id])
}

model Role {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  employees Employee[]
}